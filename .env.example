# Database connection string from Render Postgres
DATABASE_URL=

# Site name shown in metadata
NEXT_PUBLIC_SITE_NAME=Prestige Rentals

# Business phone number displayed on site
NEXT_PUBLIC_BUSINESS_PHONE=

# Admin panel password (simple gate)
ADMIN_PASSWORD=

# Stripe secret key (Dashboard -> Developers -> API keys, test mode for local dev)
STRIPE_SECRET_KEY=

# Stripe publishable key (same page as above)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Stripe webhook signing secret (Dashboard -> Developers -> Webhooks -> your endpoint)
STRIPE_WEBHOOK_SECRET=
